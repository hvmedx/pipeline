// Pipeline: CrisisView Frontend (Next.js)
// CI:  install → lint → test → SCA (npm audit) → build → SonarQube + Quality Gate
// CD:  build image → SBOM (syft) → scan (Trivy, blocking on CRITICAL) → push DockerHub → deploy → smoke test
// Rollback: redeploys the previously published :previous tag without rebuilding.

pipeline {
    agent any

    options {
        timestamps()
        ansiColor('xterm')
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    parameters {
        booleanParam(name: 'ROLLBACK', defaultValue: false,
                     description: 'Skip build/test/scan and redeploy the :previous tag.')
    }

    environment {
        IMAGE_NAME      = 'crisisview-frontend'
        DOCKERHUB_USER  = credentials('dockerhub-user')
        DOCKERHUB_CREDS = 'dockerhub-creds'
        CONTAINER_NAME  = 'crisisview-frontend'
        DEVOPS_NETWORK  = 'devops'
        IMAGE_TAG       = "${env.BUILD_NUMBER}"
        IMAGE_FULL      = "${DOCKERHUB_USER}/${IMAGE_NAME}:${IMAGE_TAG}"
        IMAGE_LATEST    = "${DOCKERHUB_USER}/${IMAGE_NAME}:latest"
        IMAGE_PREVIOUS  = "${DOCKERHUB_USER}/${IMAGE_NAME}:previous"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                dir('frontend_crisisview') {
                    sh 'node --version && npm --version'
                    sh 'npm ci'
                }
            }
        }

        stage('Lint') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                dir('frontend_crisisview') {
                    sh 'npm run lint || true'
                }
            }
        }

        stage('Test') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                dir('frontend_crisisview') {
                    sh 'npm run test:coverage'
                }
            }
        }

        stage('SCA (npm audit)') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                dir('frontend_crisisview') {
                    sh '''
                        npm audit --omit=dev --json > npm-audit.json || true
                        echo "--- npm audit summary ---"
                        npm audit --omit=dev || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'frontend_crisisview/npm-audit.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Build') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                dir('frontend_crisisview') {
                    sh 'npm run build'
                }
            }
        }

        stage('SonarQube') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                dir('frontend_crisisview') {
                    withSonarQubeEnv(installationName: 'sonarqube',
                                     credentialsId: 'sonar-token-crisisview-frontend') {
                        sh '''
                            sonar-scanner \
                                -Dsonar.host.url=$SONAR_HOST_URL \
                                -Dsonar.token=$SONAR_AUTH_TOKEN
                        '''
                    }
                }
            }
        }

        stage('Quality Gate') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build image') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                dir('frontend_crisisview') {
                    sh '''
                        docker build \
                            --build-arg BUILD_SHA=${GIT_COMMIT:-${BUILD_NUMBER}} \
                            -t ${IMAGE_FULL} \
                            -t ${IMAGE_LATEST} .
                    '''
                }
            }
        }

        stage('SBOM (syft)') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                sh '''
                    docker run --rm \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        anchore/syft:latest \
                        ${IMAGE_FULL} -o spdx-json > sbom-frontend.json
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'sbom-frontend.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Scan image (Trivy)') {
            when { not { expression { return params.ROLLBACK } } }
            steps {
                sh '''
                    rm -f trivy-frontend.json trivy-frontend.stderr
                    mkdir -p .trivy-cache
                    docker run --rm \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        -v "$PWD/.trivy-cache:/root/.cache/trivy" \
                        aquasec/trivy:latest image \
                        --severity HIGH,CRITICAL --no-progress --timeout 10m --format json \
                        ${IMAGE_FULL} > trivy-frontend.json 2> trivy-frontend.stderr || true
                    if [ ! -s trivy-frontend.json ]; then
                        echo '{"error":"trivy report was not generated"}' > trivy-frontend.json
                    fi

                    # Hard gate: fail the build on any CRITICAL.
                    docker run --rm \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        -v "$PWD/.trivy-cache:/root/.cache/trivy" \
                        aquasec/trivy:latest image \
                        --severity CRITICAL --exit-code 1 --no-progress --timeout 10m --skip-db-update --skip-java-db-update \
                        ${IMAGE_FULL}
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-frontend.json',
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Promote: push DockerHub') {
            when {
                expression {
                    def isMain = (env.BRANCH_NAME == 'main') ||
                                 (env.GIT_BRANCH == 'main') ||
                                 (env.GIT_BRANCH == 'origin/main') ||
                                 (env.GIT_LOCAL_BRANCH == 'main')
                    return isMain && !params.ROLLBACK
                }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: env.DOCKERHUB_CREDS,
                                                  usernameVariable: 'DH_USER',
                                                  passwordVariable: 'DH_PASS')]) {
                    sh '''
                        echo "$DH_PASS" | docker login -u "$DH_USER" --password-stdin

                        # Rollback safety: snapshot current :latest as :previous before overwriting.
                        if docker pull ${IMAGE_LATEST} >/dev/null 2>&1; then
                            docker tag  ${IMAGE_LATEST} ${IMAGE_PREVIOUS}
                            docker push ${IMAGE_PREVIOUS}
                        else
                            echo "No prior :latest to snapshot — first release."
                        fi

                        docker push ${IMAGE_FULL}
                        docker push ${IMAGE_LATEST}
                        docker logout
                    '''
                }
            }
        }

        stage('Deploy: docker run') {
            when {
                expression {
                    return (env.BRANCH_NAME == 'main') ||
                           (env.GIT_BRANCH == 'main') ||
                           (env.GIT_BRANCH == 'origin/main') ||
                           (env.GIT_LOCAL_BRANCH == 'main')
                }
            }
            steps {
                script {
                    def deployTag = params.ROLLBACK ? 'previous' : 'latest'
                    sh """
                        docker pull ${DOCKERHUB_USER}/${IMAGE_NAME}:${deployTag} || true
                        docker rm -f ${CONTAINER_NAME} 2>/dev/null || true
                        docker run -d \
                            --name ${CONTAINER_NAME} \
                            --network ${DEVOPS_NETWORK} \
                            --restart unless-stopped \
                            -p 3100:3000 \
                            ${DOCKERHUB_USER}/${IMAGE_NAME}:${deployTag}
                        docker image prune -f
                    """
                }
            }
        }

        stage('Smoke test') {
            when {
                expression {
                    return (env.BRANCH_NAME == 'main') ||
                           (env.GIT_BRANCH == 'main') ||
                           (env.GIT_BRANCH == 'origin/main') ||
                           (env.GIT_LOCAL_BRANCH == 'main')
                }
            }
            steps {
                sh '''
                    for i in 1 2 3 4 5; do
                        code=$(curl -o /dev/null -s -w "%{http_code}" http://crisisview-frontend:3000/ || echo 000)
                        if [ "$code" = "200" ]; then echo "Frontend OK"; exit 0; fi
                        sleep 3
                    done
                    echo "Frontend smoke test failed (last code: $code)"; exit 1
                '''
            }
        }
    }

    post {
        always {
            sh 'docker image prune -f || true'
            cleanWs()
        }
        success { echo "Build #${env.BUILD_NUMBER} (${env.IMAGE_FULL}) ${params.ROLLBACK ? 'rolled back' : 'deployed'}" }
        failure { echo "Build #${env.BUILD_NUMBER} FAILED" }
    }
}
